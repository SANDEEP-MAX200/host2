{
  "manifest_version": 3,
  "name": "Anti-Phishing Application",
  "version": "3.1",
  "description": "Scan for phishing websites",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "webNavigation",
    "cookies"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/APA_ICON.svg",
      "32": "public/APA_ICON.svg",
      "128": "public/APA_ICON.svg"
    }
  },
  "icons": {
    "16": "public/APA_ICON.svg",
    "48": "public/APA_ICON.svg",
    "128": "public/APA_ICON.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
